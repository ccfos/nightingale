        "name": "Bandwidth Usage Too High",
        "note": "1.流量值：\ndelta(snmp_network_status_incoming [1m])\n#delta() 函数用于计算时间序列数据的增量（差值）\n/8 转换倍数\nmin_over_time(metric_name [3m])\n3 \nmax_over_time(snmp_network_status_speed [30m])/1000 * 0.7 * 1024 * 1024 * 1024 \n取物理端口的70%，90%做告警",
        "prod": "metric",
        "algorithm": "",
        "algo_params": null,
        "delay": 0,
        "severity": 0,
        "severities": [
            3,
            2
        ],
        "disabled": 0,
        "prom_for_duration": 120,
        "prom_ql": "",
        "rule_config": {
            "queries": [
                {
                    "prom_ql": "min_over_time(delta(snmp_network_status_incoming[3m]) * 8 / 180 / 1024 / 1024 [3m]) \u003e snmp_network_status_speed / 1000 * 0.7 * 1024 * 1024 * 1024 and snmp_network_status_speed \u003e 0",
                    "severity": 3
                },
                {
                    "prom_ql": "min_over_time(delta(snmp_network_status_incoming[3m]) * 8 / 180 / 1024 / 1024 [3m]) \u003e snmp_network_status_speed / 1000 * 0.9 * 1024 * 1024 * 1024 and snmp_network_status_speed \u003e 0",
                    "severity": 2
                }
            ]
        },
