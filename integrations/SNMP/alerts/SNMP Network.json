                {
                    "prom_ql": "delta(snmp_network_status_incoming_errors[1m]) \u003e 100 and delta(snmp_network_status_incoming_errors[1m]) / delta(snmp_network_status_incoming_ucastpkts[1m]) \u003e 0.001",
