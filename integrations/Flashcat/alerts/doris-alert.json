          "upper_bound": 1,
          "upper_times_num": 1
        },
        "severity": 2
      },
      "nodata_trigger": {
        "resolve_after": 1800,
        "severity": 2
      },
      "queries": [
        {
          "query": "doris_be_disks_avail_capacity /1024 /1024/1024 ",
          "ref": "A",
          "unit": "none"
