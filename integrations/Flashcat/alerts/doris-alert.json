          "query": "doris_be_disks_avail_capacity / doris_be_disks_total_capacity ",
          "ref": "B",
          "unit": "none"
        }
      ],
      "triggers": [
        {
          "exp": "$A < 50 || $B < 0.2",
          "expressions": [
            {
              "comparisonOperator": ">",
              "ref": "A"
            }
          ],
          "join_ref": "A",
          "mode": 1,
          "recover_config": {
            "judge_type": 0
          },
          "severity": 2
        }
      ],
