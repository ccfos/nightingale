{
    "name": "Flashcat进程状态",
    "tags": "Flashcat自运维",
    "ident": "",
    "uuid": 1752165423091000,
    "configs": {
        "var": [
            {
                "name": "datasource",
                "type": "datasource",
                "hide": false,
                "definition": "prometheus",
                "defaultValue": 6
            },
            {
                "name": "ident",
                "type": "query",
                "hide": false,
                "datasource": {
                    "cate": "prometheus",
                    "value": "${datasource}"
                },
                "definition": "label_values(up,ident)",
                "multi": true,
                "allOption": true
            },
            {
                "name": "service",
                "type": "query",
                "hide": false,
                "datasource": {
                    "cate": "prometheus",
                    "value": "${datasource}"
                },
                "definition": "label_values(up{ident=~\"$ident.*\"},service)",
                "multi": true,
                "allOption": true
            }
        ],
        "panels": [
            {
                "type": "table",
                "id": "2f2918e4-02d5-4f1f-93eb-449bb7534375",
                "layout": {
                    "h": 13,
                    "w": 24,
                    "x": 0,
                    "y": 0,
                    "i": "2f2918e4-02d5-4f1f-93eb-449bb7534375",
                    "isResizable": true
                },
                "version": "3.1.0",
                "datasourceCate": "prometheus",
                "datasourceValue": "${datasource}",
                "targets": [
                    {
                        "refId": "A",
                        "expr": "sum(up{ident=~\"$ident.*\", service=~\"$service.*\"}) by (service,ident,instance)",
                        "legend": "部署服务:  {{service}} 部署节点: {{instance}}",
                        "step": 60,
                        "maxDataPoints": 240
                    }
                ],
                "transformations": [
                    {
                        "id": "organize",
                        "options": {}
                    }
                ],
                "name": "服务进程状态",
                "maxPerRow": 4,
                "custom": {
                    "showHeader": true,
                    "colorMode": "value",
                    "nowrap": true,
                    "tableLayout": "auto",
                    "calc": "lastNotNull",
                    "displayMode": "seriesToRows",
                    "pageLimit": 500,
                    "linkMode": "appendLinkColumn"
                },
                "options": {
                    "standardOptions": {}
                },
                "overrides": [
                    {
                        "matcher": {
                            "id": "byFrameRefID"
                        },
                        "properties": {
                            "rightYAxisDisplay": "off"
                        }
                    }
                ]
            },
            {
                "type": "timeseries",
                "id": "7800dbd6-f0cf-4915-9c4f-61978295d7c5",
                "layout": {
                    "h": 7,
                    "w": 24,
                    "x": 0,
                    "y": 13,
                    "i": "7800dbd6-f0cf-4915-9c4f-61978295d7c5",
                    "isResizable": true
                },
                "version": "3.1.0",
                "datasourceCate": "prometheus",
                "datasourceValue": "${datasource}",
                "targets": [
                    {
                        "refId": "A",
                        "expr": "docker_container_cpu_usage_percent{}",
                        "step": 60,
                        "legend": "实例: {{ident}}  服务: {{container_name}} 使用率: {{value}}",
                        "maxDataPoints": 240
                    }
                ],
                "transformations": [
                    {
                        "id": "organize",
                        "options": {}
                    }
                ],
                "name": "服务容器CPU使用率",
                "maxPerRow": 4,
                "options": {
                    "tooltip": {
                        "mode": "all",
                        "sort": "none"
                    },
                    "legend": {
                        "displayMode": "list",
                        "placement": "right",
                        "behaviour": "showItem",
                        "selectMode": "single"
                    },
                    "standardOptions": {},
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "#634CD9",
                                "value": null,
                                "type": "base"
                            }
                        ]
                    },
                    "thresholdsStyle": {
                        "mode": "dashed"
                    }
                },
                "custom": {
                    "drawStyle": "lines",
                    "lineInterpolation": "smooth",
                    "spanNulls": false,
                    "lineWidth": 1,
                    "fillOpacity": 0.5,
                    "gradientMode": "none",
                    "stack": "off",
                    "scaleDistribution": {
                        "type": "linear"
                    },
                    "showPoints": "none",
                    "pointSize": 5
                },
                "overrides": [
                    {
                        "matcher": {
                            "id": "byFrameRefID"
                        },
                        "properties": {
                            "rightYAxisDisplay": "off"
                        }
                    }
                ]
            },
            {
                "type": "timeseries",
                "id": "8ae1ebbd-8a20-4725-9dbb-2a90c9602241",
                "layout": {
                    "h": 7,
                    "w": 24,
                    "x": 0,
                    "y": 20,
                    "i": "8ae1ebbd-8a20-4725-9dbb-2a90c9602241",
                    "isResizable": true
                },
                "version": "3.1.0",
                "datasourceCate": "prometheus",
                "datasourceValue": "${datasource}",
                "targets": [
                    {
                        "refId": "A",
                        "expr": "docker_container_mem_usage_percent",
                        "legend": "实例: {{ident}}  服务: {{container_name}} 使用大小{{value}}",
                        "maxDataPoints": 240
                    }
                ],
                "transformations": [
                    {
                        "id": "organize",
                        "options": {}
                    }
                ],
                "name": "服务容器内存使用率",
                "maxPerRow": 4,
                "options": {
                    "tooltip": {
                        "mode": "all",
                        "sort": "none"
                    },
                    "legend": {
                        "displayMode": "list",
                        "placement": "right",
                        "behaviour": "showItem",
                        "selectMode": "single"
                    },
                    "standardOptions": {},
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "#634CD9",
                                "value": null,
                                "type": "base"
                            }
                        ]
                    },
                    "thresholdsStyle": {
                        "mode": "dashed"
                    }
                },
                "custom": {
                    "drawStyle": "lines",
                    "lineInterpolation": "smooth",
                    "spanNulls": false,
                    "lineWidth": 1,
                    "fillOpacity": 0.5,
                    "gradientMode": "none",
                    "stack": "off",
                    "scaleDistribution": {
                        "type": "linear"
                    },
                    "showPoints": "none",
                    "pointSize": 5
                },
                "overrides": [
                    {
                        "matcher": {
                            "id": "byFrameRefID"
                        },
                        "properties": {
                            "rightYAxisDisplay": "off"
                        }
                    }
                ]
            }
        ],
        "version": "3.0.0"
    }
}