        "version": "3.1.0",
        "links": [],
        "var": [
            {
                "type": "datasource",
                "name": "datasource",
                "definition": "prometheus",
                "hide": false
            },
            {
                "type": "query",
                "name": "regionId",
                "label": "",
                "allOption": true,
                "multi": true,
                "reg": "/^(?![--])[a-zA-Z-.0-9]/",
                "hide": false,
                "definition": "label_values(AliyunSlb_ActiveConnection{}, regionId)",
                "datasource": {
                    "cate": "prometheus",
                    "value": "${datasource}"
                }
            },
            {
                "type": "query",
                "name": "instanceName",
                "allOption": true,
                "multi": true,
                "reg": "",
                "hide": false,
                "definition": "label_values(AliyunSlb_ActiveConnection{regionId=~\"$regionId\"}, instanceName)",
                "datasource": {
                    "cate": "prometheus",
                    "value": "${datasource}"
                }
            },
            {
                "type": "query",
                "name": "instanceId",
                "allOption": true,
                "multi": true,
                "reg": "/.*instanceId=\"(.*)\",instanceName=.*/",
                "hide": false,
                "definition": "query_result(AliyunSlb_ActiveConnection{regionId=~\"$regionId\", instanceName=~\"$instanceName\" })",
                "datasource": {
                    "cate": "prometheus",
                    "value": "${datasource}"
                }
            },
            {
                "type": "query",
                "name": "vip",
                "label": "",
                "allOption": true,
                "multi": true,
                "reg": "",
                "hide": false,
                "definition": "label_values(AliyunSlb_ActiveConnection{regionId=~\"$regionId\",instanceName=~\"$instanceName\"},vip)",
                "datasource": {
                    "cate": "prometheus",
                    "value": "${datasource}"
                }
            },
            {
                "name": "ConnectionStatus",
                "type": "custom",
                "hide": false,
                "definition": "Active,Inactive,Drop,Max",
                "multi": true,
                "allOption": false
            },
            {
                "name": "RT",
                "type": "custom",
                "hide": false,
                "definition": "Listen RT : Rt,Instance RT : InstanceRt,Listen Upstream RT : UpstreamRt,Instance Upstream RT : UpstreamInstanceRt",
                "multi": true,
                "allOption": false
            },
            {
                "name": "StatusCode",
                "type": "custom",
                "hide": false,
                "definition": "Listen 2XX : StatusCode2xx,Listen 3XX : StatusCode3xx,Listen 4XX : StatusCode4xx,Listen 5XX : StatusCode5xx,Listen Other : StatusCodeOther,Listen Upstream 4XX : UpstreamCode4xx,Listen Upstream 5XX : UpstreamCode5xx,Instance 2XX : InstanceStatusCode2xx,Instance 3XX : InstanceStatusCode3xx,Instance 4XX : InstanceStatusCode4xx,Instance 5XX : InstanceStatusCode5xx,Instance Other : StatusCodeOther",
                "multi": true,
                "allOption": false
            }
        ],
