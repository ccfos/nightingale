                "definition": "label_values(huaweicloud_sys_dcs_cpu_usage{name=\"$name\"}, dcs_cluster_proxy2_node)",
                "multi": true,
                "allOption": true,
                "allValue": ".*"
            },
            {
                "name": "dcs_cluster_redis_node",
